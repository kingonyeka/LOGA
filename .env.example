NODE_ENV=development
PORT=3000

# --- Database (Postgres) ---
# Local Docker:
DATABASE_URL=postgresql://loga:loga_dev_password@localhost:5432/loga_bot
# Or Neon (if reusing hosted Postgres instead of local Docker):
# DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require

# --- Redis ---
# Local Docker:
REDIS_URL=redis://localhost:6379
# Or Upstash (TLS required — note rediss:// not redis://):
# REDIS_URL=rediss://default:<password>@<upstash-host>:6379

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change_this_to_a_random_string

# --- Google APIs (Sheets + Maps) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_MAPS_API_KEY=

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d

# --- Sentry ---
SENTRY_DSN=

# --- Church static config ---
LOGA_CHURCH_ADDRESS=
LOGA_CHURCH_LAT=
LOGA_CHURCH_LNG=
ADMIN_NOTIFICATION_GROUP_ID=